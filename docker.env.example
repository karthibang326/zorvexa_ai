# Copy to ".env" in the repository root (same folder as docker-compose.yml).
# Docker Compose reads this file automatically as `docker compose up`.
#
# For a stricter production template (HTTPS domain, AUTH_DEV_BYPASS=false), see:
#   deploy/production.env.example

# ─── Postgres ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ─── Backend security (REQUIRED — no defaults for these in production) ─
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# MUST be false in production. Only set true for isolated local dev without Auth0.
AUTH_DEV_BYPASS=false

# Enforce config validation — process exits if JWT_SECRET/AUTH settings are unsafe.
PRODUCTION_STRICT=true

# Production Auth0 validation (match your tenant + API identifier).
# AUTH_PROVIDER=auth0
# AUTH_ISSUER=https://YOUR_TENANT.us.auth0.com/
# AUTH_AUDIENCE=https://zorvexa-api

# CORS: origins that call the API from a browser (UI URL + dev ports + hosted previews).
# Include every deployed UI origin (e.g. https://your-app.vercel.app).
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://app.zorvexa.ai

# Docker API behind nginx: default true in docker-compose.yml (X-Forwarded-For for rate limits)
# TRUST_PROXY=true

# ─── Frontend image build args (Auth0 SPA — public client id is OK) ─
# After changing these, rebuild: docker compose build frontend --no-cache
# VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
# VITE_AUTH0_CLIENT_ID=your_spa_client_id
# VITE_AUTH0_AUDIENCE=https://zorvexa-api
# VITE_AUTH0_SKIP_AUDIENCE_ON_LOGIN=true
# UI served at http://localhost:3000 — add that URL to Auth0 Callback / Logout / Web Origins.
# VITE_AUTH0_REDIRECT_URI=http://localhost:3000

# Split hosting only (otherwise leave empty for same-origin /api through nginx).
# VITE_WORKFLOWS_API_URL=

# Supabase (optional — baked into the static bundle at image build time)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
