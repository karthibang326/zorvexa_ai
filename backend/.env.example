# Copy to "backend/.env". Run: cd backend && npx prisma migrate deploy && npx prisma generate

NODE_ENV=development
# Production: AUTH_DEV_BYPASS=false, strong JWT_SECRET (32+ chars), optional PRODUCTION_STRICT=true to fail boot on violations
# PRODUCTION_STRICT=false

# Dev convenience: autonomous ops loop on API boot (set false in production unless single leader)
AI_OPS_LOOP_START_ON_BOOT=true
# Must match src/lib/api.ts default (5002) unless you override the frontend VITE_WORKFLOWS_API_URL
PORT=5002

# PostgreSQL — use the URL that matches YOUR server (host, port, db, user, password).
# Example (local PG on 5434, database astraops):
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5434/astraops?schema=public"

REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-secret-change-me

# Auth0 API validation (set when frontend uses Auth0). Issuer must match token `iss` (trailing slash as issued).
# AUTH_PROVIDER=local
# AUTH_PROVIDER=auth0
# AUTH_ISSUER=https://your-tenant.us.auth0.com/
# AUTH_AUDIENCE=https://zorvexa-api

# Local dev: unauthenticated API (dev user). Omit entirely to default ON when NODE_ENV is not production/test.
# Set false to test real Auth0/JWT flows: AUTH_DEV_BYPASS=false
AUTH_DEV_BYPASS=true
# Create org-1 / proj-1 / env-prod in Postgres on startup so tenant APIs match the default UI context (set false if you intentionally removed them)
DEV_BOOTSTRAP_ORG_DEFAULT=true
# Display names for that seeded tenant (company-specific names come from Launch Mode / POST /api/org/organizations in real usage)
DEV_DEFAULT_ORG_NAME=My organization
DEV_DEFAULT_PROJECT_NAME=Default project
DEV_DEFAULT_ENV_NAME=Production
# Workspace switcher: only real DB orgs. Set true only for legacy demo without Postgres memberships.
# ALLOW_MOCK_CONTEXT_OPTIONS=false
# Include every browser origin that calls the API (local + production). Default in code includes https://zorvexa-ai.com and https://www.zorvexa-ai.com.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://localhost:5185,http://127.0.0.1:5185,https://zorvexa-ai.com,https://www.zorvexa-ai.com

# Set true when the API sits behind a reverse proxy (Docker nginx, Caddy). Default false for local :5002.
# TRUST_PROXY=false

# Multi-cloud: optional JSON map of resource name → aws|gcp|azure|kubernetes (overrides built-in demo map)
# MULTI_CLOUD_RESOURCE_MAP_JSON={"my-service":"gcp","other":"aws"}

# Live deploy: POST JSON to your pipeline when SIMULATION_MODE=false
# CLOUD_DEPLOY_WEBHOOK_URL=https://api.github.com/repos/org/repo/dispatches
# CLOUD_DEPLOY_WEBHOOK_BEARER_TOKEN=

# AWS adapter live CPU via CloudWatch (optional)
# AWS_LIVE_ADAPTER_METRICS=false
# AWS_CLOUDWATCH_NAMESPACE=AWS/EC2
# AWS_CLOUDWATCH_METRIC_NAME=CPUUtilization
# AWS_CLOUDWATCH_DIMENSIONS_JSON={"InstanceId":"i-0123456789abcdef0"}

# GCP adapter live CPU via Cloud Monitoring (optional; after OPS_METRICS_URL)
# GCP_LIVE_ADAPTER_METRICS=false
# GCP_PROJECT_ID=my-gcp-project
# GCP_MONITORING_FILTER=metric.type = "kubernetes.io/container/cpu/request_utilization" AND resource.labels.pod_name = "payments-api"

# Azure adapter live CPU via Azure Monitor (optional; after OPS_METRICS_URL)
# AZURE_LIVE_ADAPTER_METRICS=false
# AZURE_METRICS_RESOURCE_ID=/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg/providers/Microsoft.Compute/virtualMachines/myvm
# AZURE_METRICS_NAME=Percentage CPU
# AZURE_METRICS_NAMESPACE=

# --- Dashboard: AI stream + learning (synthetic loop fills UI quickly) ---
AI_DECISION_ENGINE=true
AI_STREAM_SYNTHETIC=true
AI_STREAM_INTERVAL_MS=3500
AI_STREAM_PERSIST=true
AI_DECISION_PERSIST=true
AI_LEARNING_ENABLED=true
# Tenant id for server-side learning rows (AI stream loop has no HTTP context)
AI_LEARNING_ORG_ID=org-1

# Safer default: simulation only. Set SIMULATION_MODE=false + live flags only on a test cluster.
SIMULATION_MODE=true
AI_K8S_LIVE_EXECUTION=false
# When true, decision-engine scale_up returns non-simulated execution result (still requires cloud wiring for real API calls).
AI_CLOUD_LIVE_EXECUTION=false
# When true with SIMULATION_MODE=false, AWS/GCP/Azure adapter scale+restart use the Kubernetes API (EKS/GKE/AKS kubeconfig).
# CLOUD_ADAPTER_LIVE_K8S=false

# --- Optional: real metrics for ops continuous loop (GET JSON). Maps cpu, latency, memory, errorRate, cost, logs, events ---
# OPS_METRICS_URL=http://localhost:9090/api/v1/your-adapter
# OPS_METRICS_BEARER_TOKEN=
# OPS_METRICS_TIMEOUT_MS=8000

# Razorpay (Orders API — used when billing checkout provider=razorpay). INR amounts are plan defaults in razorpay.client.ts.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# --- Stripe (pricing /api/billing/create-checkout) ---
# STRIPE_SECRET_KEY=sk_test_...   # or sk_live_... in production
# STRIPE_WEBHOOK_SECRET=whsec_...
# Create recurring Prices in Stripe Dashboard → Product catalog, then paste ids:
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# Never use in production: fake success URL without Stripe (development only).
# BILLING_DUMMY_CHECKOUT=false

# Supabase JWT verification (same URL as SPA VITE_SUPABASE_URL) so checkout & billing APIs work after Supabase login
# SUPABASE_URL=https://your-project.supabase.co

# OpenAI (Copilot + backend callLLM) — set in backend/.env or project root .env; never commit real values.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Optional: real Kubernetes (after SIMULATION_MODE=false) ---
# KUBECONFIG=/path/to/kubeconfig
# ASTRA_K8S_NAMESPACE=default
# ASTRA_K8S_DEPLOYMENT=your-deployment

# --- Optional: real cloud adapters ---
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Live ECS (before EKS/K8s bridge): SIMULATION_MODE=false + AWS_ECS_LIVE_EXECUTION=true
# AWS_ECS_LIVE_EXECUTION=false
# AWS_ECS_CLUSTER=my-cluster
# AWS_ECS_SERVICE=my-service
# GOOGLE_APPLICATION_CREDENTIALS=
# Azure: use DefaultAzureCredential / env per Azure SDK
