{
  "name": "quantumops-ai-backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.ts",
  "scripts": {
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "prisma:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:baseline": "node scripts/prisma-baseline.mjs",
    "prisma:migrate": "prisma migrate dev",
    "dev:fastify": "ts-node-dev --respawn --transpile-only src/server.ts",
    "seed": "ts-node src/seed.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.914.0",
    "@aws-sdk/client-ec2": "^3.1022.0",
    "@aws-sdk/client-ecs": "^3.1024.0",
    "@azure/identity": "^4.13.0",
    "@azure/monitor-query": "^1.3.3",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@google-cloud/monitoring": "^5.1.0",
    "@kubernetes/client-node": "^1.4.0",
    "@prisma/client": "6.14.0",
    "bullmq": "^5.56.0",
    "dotenv": "^16.3.1",
    "fastify": "^5.8.4",
    "ioredis": "^5.7.0",
    "jose": "^5.10.0",
    "mongodb": "^6.19.0",
    "openai": "^4.20.1",
    "pg": "^8.12.0",
    "prisma": "6.14.0",
    "stripe": "^21.0.1",
    "uuid": "^9.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.4.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^9.0.2",
    "@types/ws": "^8.5.13",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
