# ============================================================
# ZORVEXA — PRODUCTION ENVIRONMENT TEMPLATE
# ============================================================
# 1. Copy this file to the repository root as `.env`
# 2. Fill in ALL values marked CHANGE_ME
# 3. NEVER commit `.env` to git — it is gitignored
# 4. Rotate secrets immediately if accidentally exposed
# ============================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ─── Backend Security (REQUIRED) ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# MUST be false in production — dev bypass creates unauthenticated owner sessions
AUTH_DEV_BYPASS=false

# Abort startup if JWT_SECRET is weak or AUTH_DEV_BYPASS=true (default: true)
PRODUCTION_STRICT=true

# ─── Auth Provider ────────────────────────────────────────────────────────────
AUTH_PROVIDER=auth0
AUTH_ISSUER=https://YOUR_TENANT.us.auth0.com/
AUTH_AUDIENCE=https://zorvexa-api

# ─── CORS ────────────────────────────────────────────────────────────────────
# Exact origin(s) of your browser app — no trailing slash, no wildcards
CORS_ORIGINS=https://zorvexa-ai.com,https://www.zorvexa-ai.com

# Behind nginx/Caddy/LB: use true so rate limits use real client IP (X-Forwarded-For)
TRUST_PROXY=true

# ─── Frontend Build Args (rebuild after changes) ─────────────────────────────
# docker compose build frontend --no-cache
VITE_AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
VITE_AUTH0_CLIENT_ID=YOUR_SPA_CLIENT_ID
VITE_AUTH0_AUDIENCE=https://zorvexa-api
# VITE_AUTH0_REDIRECT_URI=https://zorvexa-ai.com

# ─── Autonomous Ops Safety ────────────────────────────────────────────────────
# Keep SIMULATION_MODE=true until you have validated cloud credentials and RBAC
SIMULATION_MODE=true
# Set false when ready to allow live cloud/K8s mutations
# SIMULATION_MODE=false

# Do NOT start the AI loop on every replica — use an external scheduler or single worker
AI_OPS_LOOP_START_ON_BOOT=false

# ─── OpenAI (optional — AI features degrade gracefully without it) ─────────────
# OPENAI_API_KEY=sk-...

# ─── Billing (optional) ───────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Bootstrap ────────────────────────────────────────────────────────────────
# Set false after first deploy to prevent re-seeding default org/project
DEV_BOOTSTRAP_ORG_DEFAULT=false

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# ─── Worker Tuning ────────────────────────────────────────────────────────────
RUN_MAX_ATTEMPTS=5
