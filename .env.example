# Copy to ".env" in this folder (frontend / Vite).
# Backend reads ../backend/.env — keep API URL in sync with backend PORT (default 5002).
#
# Vite defaults to port 5173 + strictPort. In Auth0 SPA application set (no trailing slash):
#   Allowed Callback URLs | Logout URLs | Web Origins → http://localhost:5173
# Production: add https://zorvexa-ai.com (and www / app subdomain if used) — see docs/auth0-application-checklist.md.

# Auth0 — set DOMAIN + CLIENT_ID to enable Universal Login.
# VITE_AUTH0_DOMAIN=dev-xtmaa2ls0mlwzb00.us.auth0.com
# VITE_AUTH0_CLIENT_ID=your_spa_client_id
# API identifier (access token aud). Must match backend AUTH_AUDIENCE. Authorize this API for the SPA: Applications → APIs.
# If login shows "Oops" after setting audience, authorize the API or set VITE_AUTH0_SKIP_AUDIENCE_ON_LOGIN=true
# VITE_AUTH0_AUDIENCE=https://zorvexa-api
# Optional: fixed callback if origin is wrong in rare hosting setups (must still be listed in Auth0 Callback URLs).
# VITE_AUTH0_REDIRECT_URI=https://zorvexa-ai.com
# Google Authenticator MFA: docs/auth0-google-authenticator-mfa.md
# Optional: "true" only after enabling Refresh Token Rotation + grant in Auth0 (otherwise leave unset).
# VITE_AUTH0_USE_REFRESH_TOKENS=true

# API origin — no trailing slash.
# Local dev: leave unset → `/api` (Vite proxy → port 5002).
# Production static build: leave unset only if your host proxies `/api` and `/ws` to the backend (see docker/nginx/default.conf).
# Split API host (e.g. Vercel UI + Fly/Railway API): set to your public API origin, e.g. https://api.yourdomain.com
# VITE_WORKFLOWS_API_URL=https://api.yourdomain.com

# Supabase — required for /auth. Local dev defaults: see committed `.env.development` + run `npm run supabase:start`.
# Hosted: uncomment and paste from Dashboard → Settings → API (do not leave empty `VITE_*=` lines in `.env`).
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
# Set backend SUPABASE_URL to the same origin (no trailing slash) so /api/billing/* accepts Supabase access tokens.
# TOTP (Google Authenticator) on every login: enable MFA in Supabase → Authentication → Sign in / Providers.
# Default is required; set false only for local demos without MFA.
# VITE_REQUIRE_TOTP_MFA=false

# Optional: OpenAI for copilot features
# OPENAI_API_KEY=
